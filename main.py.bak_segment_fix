    def notes_widget(self) -> tk.Text:
        return self.inputs["notes"]

    def selected_note_text(self) -> tuple[str, str, str] | None:
        widget = self.notes_widget()
        try:
            start = widget.index("sel.first")
            end = widget.index("sel.last")
            return start, end, widget.get(start, end)
        except tk.TclError:
            return None

    def wrap_selected_text(self, prefix: str, suffix: str):
        widget = self.notes_widget()
        selected = self.selected_note_text()
        if selected:
            start, end, text = selected
            widget.delete(start, end)
            widget.insert(start, f"{prefix}{text}{suffix}")
        else:
            widget.insert("insert", f"{prefix}{suffix}")
            widget.mark_set("insert", f"insert-{len(suffix)}c")

    def insert_note_prefix(self, prefix: str):
        self.notes_widget().insert("insert linestart", prefix)

    def insert_note_timestamp(self):
        widget = self.notes_widget()
        prefix = "\n\n" if widget.get("1.0", END).strip() else ""
        widget.insert("end", f"{prefix}[{now_text()}]\n")
        widget.see("end")

    def insert_note_link(self):
        widget = self.notes_widget()
        selected = self.selected_note_text()
        url = simpledialog.askstring("Ã™â€žÃ›Å’Ã™â€ ÃšÂ©", "Ã˜Â¢Ã˜Â¯Ã˜Â±Ã˜Â³ Ã™â€žÃ›Å’Ã™â€ ÃšÂ© Ã˜Â±Ã˜Â§ Ã™Ë†Ã˜Â§Ã˜Â±Ã˜Â¯ ÃšÂ©Ã™â€ Ã›Å’Ã˜Â¯:", parent=self)
        if not url:
            return
        label = selected[2] if selected else url
        markdown = f"[{label}]({url.strip()})"
        if selected:
            widget.delete(selected[0], selected[1])
            widget.insert(selected[0], markdown)
        else:
            widget.insert("insert", markdown)

    def build_notes_payload(self, raw_notes: str) -> str:
        text = raw_notes.strip()
        if not text:
            return ""
        if not self.original_notes:
            return f"[{now_text()}]\n{text}"
        if text == self.original_notes.strip():
            return self.original_notes
        original = self.original_notes.strip()
        if text.startswith(original):
            appended = text[len(original) :].strip()
            if appended:
                return f"{original}\n\n[{now_text()}]\n{appended}"
            return original
        return f"{original}\n\n[{now_text()}]\n{text}"

    def reminder_counts_for_month(self, year: int, month: int) -> dict[int, int]:
        counts: dict[int, int] = defaultdict(int)
        for item in self.existing_deals:
            if item.get("id") == self.original_deal_id:
                continue
            due = parse_jalali_datetime(item.get("reminder_at", ""))
            if due is None:
                continue
            jalali_due = jdatetime.datetime.fromgregorian(datetime=due)
            if jalali_due.year == year and jalali_due.month == month:
                counts[jalali_due.day] += 1
        return dict(counts)

    def recent_customer_values(self) -> list[str]:
        ordered = sorted(self.customers, key=lambda item: item.get("updated_at", item.get("created_at", "")), reverse=True)
        return [item["name"] for item in ordered[:8]]

